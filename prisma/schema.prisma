generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Brand {
  id               String   @id @default(cuid())
  name             String
  active           Boolean  @default(true)
  contactName      String?
  email            String?
  phone            String?
  website          String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  orders           Order[]
  pharmacyConfigs  BrandPharmacyConfig[]
  refillRequests   RefillRequest[]
}

model BrandPharmacyConfig {
  id               String   @id @default(cuid())
  brandId          String
  pharmacyId       String
  isActive         Boolean  @default(true)
  isDefault        Boolean  @default(false)
  routingPriority  Int      @default(0)
  formatPreference String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  brand            Brand    @relation(fields: [brandId], references: [id])
  pharmacy         Pharmacy @relation(fields: [pharmacyId], references: [id])

  @@unique([brandId, pharmacyId])
}

model Patient {
  id         String   @id @default(cuid())
  firstName  String
  lastName   String
  dob        String
  phone      String?
  email      String?
  address1   String?
  address2   String?
  city       String?
  state      String?
  zip        String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  orders         Order[]
  refillRequests RefillRequest[]
}

model Prescriber {
  id         String   @id @default(cuid())
  name       String
  npi        String   @unique
  clinicName String?
  phone      String?
  fax        String?
  email      String?
  address    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  orders     Order[]
}

model Pharmacy {
  id               String    @id @default(cuid())
  name             String
  contactName      String?
  phone            String?
  fax              String?
  email            String?
  street           String?
  city             String?
  state            String?
  zip              String?
  serviceStates    String?  // JSON array of US state abbreviations, e.g. ["TX","CA","NY"]
  formatPreference String   @default("standard")
  requirementsJson String   @default("{}")
  archivedAt       DateTime? // null = active; set to archive
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  orders           Order[]
  transmissions    OrderTransmission[]
  exportBatches    ExportBatch[]
  brandConfigs     BrandPharmacyConfig[]
  medicationPriceHistory MedicationPriceEntry[]
  refillRequests   RefillRequest[]
}

model Medication {
  id         String   @id @default(cuid())
  name       String
  form       String
  strength   String
  sellPrice  Float?   // Rx-Bridge negotiated sell price — same for all brands
  createdAt  DateTime @default(now())
  priceHistory MedicationPriceEntry[]
}

model MedicationPriceEntry {
  id                 String    @id @default(cuid())
  medicationId       String
  pharmacyId         String
  price              Float
  effectiveDate      DateTime  @default(now())
  endDate            DateTime? // null = currently active
  notes              String?
  verifiedAt         DateTime? // last verification timestamp
  verificationSource String?   // "manual_update" | "pharmacy_confirmed" | "contract_import" | "system_import"
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  medication         Medication @relation(fields: [medicationId], references: [id])
  pharmacy           Pharmacy   @relation(fields: [pharmacyId], references: [id])
}

model Order {
  id             String   @id @default(cuid())
  brandId        String?
  patientId      String
  prescriberId   String
  pharmacyId     String

  medicationName String
  strength       String?
  dosageForm     String?
  route          String?
  directions     String?
  quantity       Int?
  refills        Int      @default(0)
  daysSupply     Int?
  icd10          String?
  rxNotes        String?

  orderSource    String   @default("manual")
  sourceRef      String?
  priority       String   @default("normal")
  internalNotes  String?
  status         String   @default("draft")

  // Send Readiness — computed from open issues. Separate from human-driven status.
  sendReadiness  String   @default("missing_data")

  // Pricing — JSON string: { gpoPrice, retailEstimate, savingsAbsolute, savingsPercent }
  pricingJson    String?

  // Routing — how the pharmacy was selected
  routingMethod  String?  // "auto" | "manual" | null (legacy)
  routingJson    String?  // JSON: { recommendedPharmacyId, price, reason, alternatives, computedAt }

  rawPayload     String?

  completedAt    DateTime? // set when order reaches completed status
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  brand          Brand?        @relation(fields: [brandId], references: [id])
  patient        Patient       @relation(fields: [patientId], references: [id])
  prescriber     Prescriber    @relation(fields: [prescriberId], references: [id])
  pharmacy       Pharmacy      @relation(fields: [pharmacyId], references: [id])
  statusHistory      OrderStatusHistory[]
  issues             Issue[]
  transmissions      OrderTransmission[]
  correctionRequests CorrectionRequest[]
  refillRequests     RefillRequest[]
}

model OrderStatusHistory {
  id        String   @id @default(cuid())
  orderId   String
  status    String
  note      String?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id])
}

// Unified issue model — single source of truth for why an order is blocked.
model Issue {
  id             String    @id @default(cuid())
  orderId        String
  type           String    @default("missing_required_field") // missing_required_field, validation_warning, clarification_request, manual_review
  severity       String    @default("blocking") // blocking, warning, info
  source         String    @default("system") // system, rx_bridge_user, brand, pharmacy
  fieldPath      String?   // dot-path like "medication.directions", null for manual issues
  title          String
  message        String
  status         String    @default("open") // open, resolved, dismissed
  resolutionNote String?
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?
  order          Order     @relation(fields: [orderId], references: [id])
}

model CorrectionRequest {
  id            String    @id @default(cuid())
  orderId       String
  reason        String    // summary of what needs correcting
  requestedFrom String   // "provider" | "clinician" | "brand"
  message       String?   // detailed message to the recipient
  status        String    @default("open") // open | resolved
  resolvedAt    DateTime?
  resolutionNote String?
  createdAt     DateTime  @default(now())
  order         Order     @relation(fields: [orderId], references: [id])
}

model OrderTransmission {
  id              String       @id @default(cuid())
  orderId         String
  pharmacyId      String
  method          String       @default("manual")
  payloadSnapshot String
  overrideUsed    Boolean      @default(false)
  batchId         String?
  sentAt          DateTime     @default(now())
  order           Order        @relation(fields: [orderId], references: [id])
  pharmacy        Pharmacy     @relation(fields: [pharmacyId], references: [id])
  batch           ExportBatch? @relation(fields: [batchId], references: [id])
}

model ExportBatch {
  id            String              @id @default(cuid())
  pharmacyId    String
  method        String              @default("lifefile_csv")
  fileName      String
  orderCount    Int
  createdAt     DateTime            @default(now())
  pharmacy      Pharmacy            @relation(fields: [pharmacyId], references: [id])
  transmissions OrderTransmission[]
}

model RefillRequest {
  id                String    @id @default(cuid())
  orderId           String    // the original prescription/order being refilled
  brandId           String?
  patientId         String
  pharmacyId        String
  medicationName    String
  quantity          Int?
  notes             String?

  status            String    @default("pending_validation")
  source            String    @default("api") // brand_portal | api | internal_ops
  idempotencyKey    String?   @unique

  requestedByUserId String?
  requestedByName   String?
  requestedByEmail  String?

  rejectionCode     String?
  rejectionReason   String?

  // Pharmacy fill data
  pharmacyOrderId   String?
  quantityDispensed Int?
  pharmacyCostCents Int?
  sellPriceCents    Int?

  createdAt         DateTime  @default(now())
  validatedAt       DateTime?
  sentToPharmacyAt  DateTime?
  filledAt          DateTime?
  cancelledAt       DateTime?

  order             Order     @relation(fields: [orderId], references: [id])
  brand             Brand?    @relation(fields: [brandId], references: [id])
  patient           Patient   @relation(fields: [patientId], references: [id])
  pharmacy          Pharmacy  @relation(fields: [pharmacyId], references: [id])
}
