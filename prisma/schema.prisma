generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model Brand {
  id          String    @id @default(cuid())
  name        String
  active      Boolean   @default(true)
  contactName String?
  email       String?
  phone       String?
  website     String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  programs    Program[]
  fillRecords FillRecord[]
}

model Pharmacy {
  id            String    @id @default(cuid())
  name          String
  contactName   String?
  phone         String?
  fax           String?
  email         String?
  street        String?
  city          String?
  state         String?
  zip           String?
  serviceStates String?   // JSON array of US state abbreviations
  archivedAt    DateTime?
  // Contract term — contract-level, not per medication
  contractEffectiveFrom    DateTime? // when this contract version starts
  contractEffectiveThrough DateTime? // when this contract version ends
  contractStatus           String    @default("active") // active | superseded
  contractSupersededAt     DateTime?
  // Contract verification
  contractVerifiedAt     DateTime?
  contractVerifiedBy     String?   // user identifier
  contractVerificationMethod String? // confirmed | imported | estimated | renewal
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  medicationPriceHistory MedicationPriceEntry[]
  programs       Program[]
  fillRecords    FillRecord[]
  medSpaOrders   MedSpaOrder[]
  contractAuditLogs ContractAuditLog[]
}

model Medication {
  id         String   @id @default(cuid())
  name       String
  form       String
  strength   String
  sellPrice  Float?   // legacy — use ProgramPricing for current price
  createdAt  DateTime @default(now())
  priceHistory     MedicationPriceEntry[]
  programPricing   ProgramPricing[]
  programs         Program[]
  fillRecords      FillRecord[]
  medSpaOrders     MedSpaOrder[]
}

// Versioned program pricing — the global price Rx-Bridge charges med spas
model ProgramPricing {
  id               String    @id @default(cuid())
  medicationId     String
  price            Float
  effectiveFrom    DateTime
  effectiveThrough DateTime?
  status           String    @default("active") // active | superseded
  supersededAt     DateTime?
  notes            String?
  createdBy        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  medication       Medication @relation(fields: [medicationId], references: [id])
}

model MedicationPriceEntry {
  id                 String    @id @default(cuid())
  medicationId       String
  pharmacyId         String
  price              Float
  effectiveDate      DateTime  @default(now())
  endDate            DateTime?
  notes              String?
  verifiedAt         DateTime?
  verificationSource String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  medication         Medication @relation(fields: [medicationId], references: [id])
  pharmacy           Pharmacy   @relation(fields: [pharmacyId], references: [id])
}

// A pricing contract between a brand and pharmacy for a specific medication
model Program {
  id             String    @id @default(cuid())
  brandId        String
  pharmacyId     String
  medicationId   String
  negotiatedRate Float
  effectiveStart DateTime
  effectiveEnd   DateTime?
  referenceCode  String    @unique
  status         String    @default("active") // active | inactive | expired
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  brand          Brand      @relation(fields: [brandId], references: [id])
  pharmacy       Pharmacy   @relation(fields: [pharmacyId], references: [id])
  medication     Medication @relation(fields: [medicationId], references: [id])

  @@unique([brandId, pharmacyId, medicationId])
}

model MedSpa {
  id               String        @id @default(cuid())
  name             String
  city             String?
  state            String?
  contactName      String?
  email            String?
  phone            String?
  pipelineStage    String        @default("lead") // lead | contacted | pricing_requested | pricing_sent | negotiating | won | lost
  currentVendor    String?       // e.g. "Direct from pharmacy", "Another GPO"
  estMonthlyVolume String?       // e.g. "$5,000 - $10,000"
  nextStep         String?       // free text: "Schedule pricing call", "Send proposal"
  lastContactedAt  DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  orders           MedSpaOrder[]
  pricingLines     MedSpaPricingLine[]
  notes            MedSpaNote[]
  fulfilledOrders  MedSpaFulfilledOrder[]
  pricingAgreements MedSpaPricingAgreement[]
  statements       MedSpaStatement[]
  proposals        MedSpaProposal[]
}

// Proposal sent to a med spa client — tracks send/view/accept lifecycle
model MedSpaProposal {
  id               String    @id @default(cuid())
  medSpaId         String
  status           String    @default("draft") // draft | sent | viewed | accepted
  recipientEmail   String?
  message          String?
  sentAt           DateTime?
  viewedAt         DateTime?
  acceptedAt       DateTime?
  monthlySavings   Float     @default(0)
  monthlyProfit    Float     @default(0)
  pricingSnapshot  String    // JSON of proposed pricing rows
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  medSpa           MedSpa    @relation(fields: [medSpaId], references: [id])
}

// Monthly statement — tracks what a med spa owes for a given month
model MedSpaStatement {
  id             String    @id @default(cuid())
  medSpaId       String
  month          String    // YYYY-MM format
  status         String    @default("draft") // draft | sent | paid | overdue
  statementDate  DateTime?
  dueDate        DateTime?
  totalScripts   Int       @default(0)
  pharmacySpend  Float     @default(0)
  biskFees       Float     @default(0)
  totalCost      Float     @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  medSpa         MedSpa    @relation(fields: [medSpaId], references: [id])

  @@unique([medSpaId, month])
}

// Versioned pricing agreement — what the med spa has agreed to pay
model MedSpaPricingAgreement {
  id               String    @id @default(cuid())
  medSpaId         String
  status           String    @default("draft") // draft | active | superseded | expired
  effectiveFrom    DateTime
  effectiveThrough DateTime
  notes            String?
  createdBy        String?
  supersededAt     DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  medSpa           MedSpa    @relation(fields: [medSpaId], references: [id])
  lines            MedSpaPricingAgreementLine[]
}

// Individual medication line within an agreement
model MedSpaPricingAgreementLine {
  id                 String   @id @default(cuid())
  agreementId        String
  medicationId       String
  medicationName     String   // denormalized for display
  agreedPrice        Float
  pharmacyId         String?  // selected pharmacy for fulfillment
  pharmacyName       String?  // denormalized
  estimatedMonthlyQty Int?
  createdAt          DateTime @default(now())
  agreement          MedSpaPricingAgreement @relation(fields: [agreementId], references: [id])
}

// User-entered current pricing for a med spa (what they pay today)
model MedSpaPricingLine {
  id              String    @id @default(cuid())
  medSpaId        String
  medicationName  String
  currentCost     Float
  unit            String    @default("unit") // capsule, vial, tube, bottle, unit
  monthlyQty      Int
  currentVendor   String?
  pricingSource   String?   // e.g. "Invoice", "Verbal quote", "Website"
  confirmedAt     DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  medSpa          MedSpa    @relation(fields: [medSpaId], references: [id])
}

// Activity log for deal tracking
model MedSpaNote {
  id        String   @id @default(cuid())
  medSpaId  String
  note      String
  type      String   @default("note") // note | call | email | meeting | pricing | follow_up
  createdAt DateTime @default(now())
  medSpa    MedSpa   @relation(fields: [medSpaId], references: [id])
}

// Actual fulfilled orders — post-close performance tracking
model MedSpaFulfilledOrder {
  id                   String   @id @default(cuid())
  orderNumber          String?  @unique // ORD-YYYYMM-### format
  medSpaId             String
  orderDate            DateTime
  medicationName       String
  quantity             Int
  pharmacyName         String
  medSpaPaid           Float    // what the med spa actually paid (revenue)
  pharmacyCost         Float    // what the pharmacy actually billed
  contractPriceAtTime  Float?   // expected contract price per unit at time of order
  biskFeeAtTime        Float?   // Bisk fee per script at time of order
  status               String   @default("fulfilled") // fulfilled | pending | sent_to_pharmacy | delivered
  notes                String?
  createdAt            DateTime @default(now())
  medSpa               MedSpa   @relation(fields: [medSpaId], references: [id])
}

model MedSpaOrder {
  id           String     @id @default(cuid())
  medSpaId     String
  medicationId String
  pharmacyId   String
  quantity     Int
  unitCost     Float      // what the med spa actually paid per unit
  createdAt    DateTime   @default(now())
  medSpa       MedSpa     @relation(fields: [medSpaId], references: [id])
  medication   Medication @relation(fields: [medicationId], references: [id])
  pharmacy     Pharmacy   @relation(fields: [pharmacyId], references: [id])
}

// Actual pharmacy fill record for reconciliation
model FillRecord {
  id            String   @id @default(cuid())
  referenceCode String
  medicationId  String
  pharmacyId    String
  brandId       String
  quantity      Int
  actualRate    Float
  expectedRate  Float
  variance      Float    // actualRate - expectedRate
  status        String   @default("missing") // match | mismatch | missing
  fillDate      DateTime
  resolvedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  medication    Medication @relation(fields: [medicationId], references: [id])
  pharmacy      Pharmacy   @relation(fields: [pharmacyId], references: [id])
  brand         Brand      @relation(fields: [brandId], references: [id])
}

// Contract-level audit log for pharmacy pricing changes
model ContractAuditLog {
  id                 String   @id @default(cuid())
  pharmacyId         String
  actionType         String   // created | updated | verified | deleted
  changedFields      String?  // JSON summary of changes
  performedBy        String?  // user identifier
  notes              String?
  performedAt        DateTime @default(now())
  pharmacy           Pharmacy @relation(fields: [pharmacyId], references: [id])
}
